# Supabase credentials — get these from your Supabase project settings
# (Settings → API → Project URL and anon/public key)
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Email notifications (Phase 3 — automated sending via Resend)
# Set these as Supabase Edge Function secrets, not in .env.local:
#   supabase secrets set RESEND_API_KEY=re_...
#   supabase secrets set LUMA_FROM_EMAIL="Org Name Recruiting <recruiting@yourdomain.com>"
#
# Without RESEND_API_KEY the edge function runs in dry-run mode and returns
# a count of emails that would be sent (no emails are delivered).
